{
  "permissions": {
    "allow": [
      "WebFetch(domain:raw.githubusercontent.com)",
      "PowerShell(Rename-Item -Path \"backend\" -NewName \"shared\")",
      "PowerShell(if \\($?\\) { \"renamed\" })",
      "PowerShell(\"removed monolith entry + old Dockerfile\")",
      "PowerShell(Get-ChildItem -Path infra -Recurse -File | ForEach-Object { $_.FullName.Replace\\(\\(Get-Location\\).Path + '\\\\',''\\) })",
      "PowerShell(Get-ChildItem -Recurse -Directory shared/app, services | Where-Object { $_.FullName -notmatch 'node_modules|__pycache__|\\\\.git' } | Select-Object FullName | ForEach-Object { $_.FullName.Replace\\(\\(Get-Location\\).Path + '\\\\',''\\) })",
      "PowerShell(Get-ChildItem -Recurse -File shared/app | Where-Object { $_.FullName -notmatch '__pycache__' } | Select-Object @{n='Path';e={$_.FullName.Replace\\(\\(Get-Location\\).Path + '\\\\',''\\)}}, @{n='KB';e={[math]::Round\\($_.Length/1KB,1\\)}} | Format-Table -AutoSize)",
      "PowerShell(Get-ChildItem shared -Filter entrypoint.sh -Recurse | ForEach-Object { $_.FullName }; Write-Output \"---gateway nginx ports---\"; Select-String -Path gateway/nginx.conf -Pattern \"listen|proxy_pass|location\" | Select-Object -First 30 | ForEach-Object { $_.Line.Trim\\(\\) })",
      "PowerShell(Get-ChildItem -Recurse infra | Where-Object { $_.FullName -notmatch '\\\\.git' } | Select-Object @{n='Path';e={$_.FullName.Replace\\(\\(Get-Location\\).Path + '\\\\',''\\)}}, @{n='Type';e={if\\($_.PSIsContainer\\){'DIR'}else{'FILE'}}} | Format-Table -AutoSize)",
      "WebFetch(domain:github.com)",
      "PowerShell(Get-ChildItem -Recurse infra -Force | Where-Object { -not $_.PSIsContainer } | ForEach-Object { $_.FullName.Replace\\(\\(Get-Location\\).Path + '\\\\',''\\) } | Sort-Object)",
      "PowerShell(winget install --id Docker.DockerDesktop -e --source winget --accept-source-agreements --accept-package-agreements --scope machine 2>&1)"
    ]
  }
}

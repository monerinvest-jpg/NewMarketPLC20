# Environment
.env
.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
venv/
*.egg-info/
.pytest_cache/

# Node
node_modules/
dist/
dist-ssr/
*.local

# Logs
*.log
npm-debug.log*

# Editor
.vscode/
.idea/
*.swp
.DS_Store

# Docker volumes data (if mounted locally)
postgres_data/
uploads_data/

# Uploads (runtime data)
shared/app/uploads/*
!shared/app/uploads/.gitkeep

# ── Infra secrets / state (дублируем как защитную сетку; в infra/* свои .gitignore) ──
# Ключ сервис-аккаунта, переменные с секретами, стейт и сгенерированный инвентарь
key.json
*.tfvars
!*.tfvars.example
*.tfstate
*.tfstate.*
.terraform/
hosts.ini
# Terraform saved plans embed sensitive values (DB/Redis passwords)
tfplan
tfplan*
*.tfplan
# CA-сертификат Managed PostgreSQL и расшифрованные секреты Ansible
infra/ansible/files/root.crt
infra/ansible/group_vars/all/vault.yml

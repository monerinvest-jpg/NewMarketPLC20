# ============================================================
# APPLICATION
# ============================================================
APP_ENV=development
SECRET_KEY=change-me-super-secret-key-at-least-32-chars
# Separate secret for refresh tokens (infra passes REFRESH_SECRET_KEY).
# Leave empty to reuse SECRET_KEY.
REFRESH_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
# Infra passes JWT_ALGORITHM; ALGORITHM is the local alias.
ALGORITHM=HS256

# ============================================================
# DATABASE — PostgreSQL (Yandex Managed PostgreSQL via the 6432 pooler in prod)
# ============================================================
# In the cloud, Ansible injects a ready-made DATABASE_URL and the DB_* parts.
# Locally, leave DATABASE_URL empty to assemble it from the DB_* values below.
DB_HOST=db
DB_PORT=5432
DB_USER=marketplace
DB_PASSWORD=marketplace_password
DB_NAME=marketplace
DATABASE_URL=
# Yandex Managed PostgreSQL requires TLS. In the cloud set DB_SSL=true and point
# DB_SSL_ROOT_CERT at the Yandex CA bundle. Locally keep it false.
DB_SSL=false
DB_SSL_ROOT_CERT=

# ============================================================
# REDIS (Yandex Managed Redis in prod; infra passes a single REDIS_URL)
# ============================================================
REDIS_URL=redis://redis:6379/0
# Celery defaults to REDIS_URL when these are empty.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ============================================================
# YOOKASSA
# ============================================================
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
YOOKASSA_RETURN_URL=http://localhost:3000/payment/return

# FISCALIZATION (54-ФЗ, встроенная фискализация ЮKassa)
FISCAL_ENABLED=true
FISCAL_VAT_CODE=1
FISCAL_TAX_SYSTEM_CODE=0
FISCAL_PAYMENT_SUBJECT=commodity
FISCAL_PAYMENT_MODE=full_prepayment
FISCAL_AGENT_SCHEME=false

# ============================================================
# FRONTEND URL (used to build links in emails, e.g. password reset)
# ============================================================
FRONTEND_URL=http://localhost:3000

# ============================================================
# SMTP (optional — leave SMTP_HOST empty to log emails instead of sending)
# ============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@marketplace.com

# ============================================================
# CDEK (СДЭК)
# ============================================================
CDEK_CLIENT_ID=your_cdek_client_id
CDEK_CLIENT_SECRET=your_cdek_client_secret
CDEK_API_URL=https://api.edu.cdek.ru/v2

# ============================================================
# OTHER DELIVERY SERVICES (optional — mock used when empty)
# ============================================================
OZON_API_KEY=
OZON_CLIENT_ID=
YANDEX_DELIVERY_TOKEN=
RUSSIAN_POST_TOKEN=
RUSSIAN_POST_ACCESS_KEY=

# ============================================================
# CORS
# ============================================================
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ============================================================
# FRONTEND (used in docker-compose)
# ============================================================
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=Marketplace

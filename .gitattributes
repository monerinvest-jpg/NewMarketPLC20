# Нормализация переводов строк. В репозитории храним LF.
* text=auto eol=lf

# Файлы, которые ОБЯЗАТЕЛЬНО должны остаться с LF (исполняются в Linux-контейнерах).
# Иначе CRLF ломает shebang / sh-парсинг.
*.sh        text eol=lf
entrypoint.sh text eol=lf
Dockerfile  text eol=lf
*.tpl       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.cfg       text eol=lf

# Бинарные файлы — git их не трогает.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.woff  binary
*.woff2 binary

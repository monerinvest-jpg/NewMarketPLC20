# Alertmanager config (rendered by observability.yml).
# Telegram receiver activates only when telegram_bot_token/telegram_chat_id are
# set (ansible -e or [all:vars]); otherwise alerts are visible in the
# Alertmanager UI (:9093, in-VPC) and on the Grafana alert panel.
route:
  receiver: {{ 'telegram' if (telegram_bot_token | default('')) else 'void' }}
  group_by: ['alertname']
  group_wait: 30s
  group_interval: 5m
  # Re-notify about still-firing alerts every 4h (not every eval).
  repeat_interval: 4h

receivers:
  - name: void
{% if telegram_bot_token | default('') %}
  - name: telegram
    telegram_configs:
      - bot_token: '{{ telegram_bot_token }}'
        chat_id: {{ telegram_chat_id }}
        api_url: https://api.telegram.org
        parse_mode: HTML
        message: |-
          {% raw %}{{ range .Alerts }}{{ if eq .Status "firing" }}🔴{{ else }}✅{{ end }} <b>{{ .Labels.alertname }}</b>
          {{ .Annotations.summary }}
          {{ .Annotations.description }}
          {{ end }}{% endraw %}
{% endif %}
